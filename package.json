{
  "name": "focus-browser",
  "version": "0.1.0",
  "private": true,
  "description": "Minimalist, strictly-local focus browser (Windows)",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build:icon": "node scripts/build-icon.js",
    "dist": "npm run build:icon && electron-builder",
    "release": "node scripts/release.js"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.focusbrowser.app",
    "productName": "Focus Browser",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
